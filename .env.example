# TranscriptDB Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API key (optional — for AI-powered search)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Where downloaded course media (videos, Notion snapshots) is stored.
# Defaults to /Volumes/GMLDAS/Development/Software/General/ffa-transcript-db-media
# if unset. The directory is created automatically on first run.
MEDIA_LIBRARY_PATH=
